# ============================================================================
# Email Notification Service - Configuración
# Autor: Anthony Martinez
# ============================================================================

# ============================================================================
# BASE DE DATOS - Parámetros individuales (se construye automáticamente)
# ============================================================================

# Tipo de base de datos: postgresql, mysql, mssql
DATABASE_TYPE=postgresql

# Host de la base de datos
DATABASE_HOST=localhost

# Puerto de la base de datos
# PostgreSQL: 5432
# MySQL: 3306
# SQL Server: 1433
DATABASE_PORT=5432

# Nombre de la base de datos
DATABASE_NAME=email_notification_db

# Usuario de la base de datos
DATABASE_USER=postgres

# Contraseña de la base de datos
DATABASE_PASSWORD=password

# Configuración de pool de conexiones
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ============================================================================
# FASTAPI
# ============================================================================
DEBUG=True
API_TITLE=Email Notification Service
API_VERSION=1.0.0

# ============================================================================
# SMTP CONFIGURATION (para envío vía SMTP)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Email Notification Service

# ============================================================================
# MICROSOFT GRAPH / O365 CONFIGURATION (para envío vía Microsoft Graph)
# ============================================================================
# Obtener estos valores desde Azure Portal:
# 1. Ir a Azure Portal > App registrations
# 2. Crear nueva aplicación
# 3. Copiar Client ID y Tenant ID
# 4. Crear Client Secret
# 5. Agregar permisos: Mail.Send

O365_CLIENT_ID=your-client-id
O365_CLIENT_SECRET=your-client-secret
O365_TENANT_ID=your-tenant-id

# ============================================================================
# REDIS (para cola de tareas)
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ============================================================================
MAX_UPLOAD_SIZE=10485760
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
EMAIL_TIMEOUT=30
MAX_RETRIES=3
